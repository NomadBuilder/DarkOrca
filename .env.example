# Resend Email Configuration (same as DarkAI-consolidated)
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=onboarding@resend.dev
FROM_NAME=DarkOrca
BASE_URL=http://localhost:5001

# Optional: SMTP Fallback
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Optional: AI-Powered PDF Analysis
# Set this to enable AI-generated executive analysis section in PDF reports
# Supports OpenAI API (models: gpt-4o-mini, gpt-4, etc.) or Anthropic Claude
# OPENAI_API_KEY=sk-your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini  # Optional: specify model (default: gpt-4o-mini)
# Or use AI_API_KEY as alternative variable name
